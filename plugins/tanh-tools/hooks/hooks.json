{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/check.sh",
            "statusMessage": "Formatting, linting, type-checking…"
          }
        ]
      }
    ]
  }
}
